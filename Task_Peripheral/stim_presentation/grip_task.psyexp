        <Param val="from pylsl import StreamInfo, StreamOutlet&amp;#10;&amp;#10;# Instantiate the StreamInfo&amp;#10;info = StreamInfo(name='PsychoPy_Markers',&amp;#10;                  type='Markers',&amp;#10;                  channel_count=1,&amp;#10;                  nominal_srate=0,&amp;#10;                  channel_format='string',&amp;#10;                  source_id='griptask')&amp;#10;&amp;#10;# Create the outlet — your single pipe for all events&amp;#10;outlet = StreamOutlet(info)&amp;#10;&amp;#10;t_grayscreen_on = None&amp;#10;&amp;#10;thisExpLog = data.ExperimentHandler(&amp;#10;            name=expName,&amp;#10;            version='1.0',&amp;#10;            extraInfo=expInfo,&amp;#10;            runtimeInfo=None,&amp;#10;            dataFileName='{}_stimulus_times'.format(filename)&amp;#10;            )&amp;#10;thisExpPulses = data.ExperimentHandler(&amp;#10;            name=expName,&amp;#10;            version='1.0',&amp;#10;            extraInfo=expInfo,&amp;#10;            runtimeInfo=None,&amp;#10;            dataFileName='{}_pulses'.format(filename)&amp;#10;            )&amp;#10;            &amp;#10;            &amp;#10;allowedKeys = ['t', 'T', '5', 'escape', 'space']&amp;#10;conditionsFile = './conditions/'+ expInfo['paradigm (fmri, ultrasound, or emg)']+'/'+expInfo['conditions file']&amp;#10;print(conditionsFile)" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="import {StreamInfo, StreamOutlet} from 'pylsl';&amp;#10;info = new StreamInfo({&quot;name&quot;: &quot;PsychoPy_Markers&quot;, &quot;type&quot;: &quot;Markers&quot;, &quot;channel_count&quot;: 1, &quot;nominal_srate&quot;: 0, &quot;channel_format&quot;: &quot;string&quot;, &quot;source_id&quot;: &quot;griptask&quot;});&amp;#10;outlet = new StreamOutlet(info);&amp;#10;t_grayscreen_on = null;&amp;#10;thisExpLog = new data.ExperimentHandler({&quot;name&quot;: expName, &quot;version&quot;: &quot;1.0&quot;, &quot;extraInfo&quot;: expInfo, &quot;runtimeInfo&quot;: null, &quot;dataFileName&quot;: &quot;{}_stimulus_times&quot;.format(filename)});&amp;#10;thisExpPulses = new data.ExperimentHandler({&quot;name&quot;: expName, &quot;version&quot;: &quot;1.0&quot;, &quot;extraInfo&quot;: expInfo, &quot;runtimeInfo&quot;: null, &quot;dataFileName&quot;: &quot;{}_pulses&quot;.format(filename)});&amp;#10;allowedKeys = [&quot;t&quot;, &quot;T&quot;, &quot;5&quot;, &quot;escape&quot;, &quot;space&quot;];&amp;#10;conditionsFile = (((&quot;./conditions/&quot; + expInfo[&quot;paradigm (fmri, ultrasound, or emg)&quot;]) + &quot;/&quot;) + expInfo[&quot;conditions file&quot;]);&amp;#10;console.log(conditionsFile);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="sides = [&quot;L&quot;, &quot;R&quot;];&amp;#10;screen_position = {&quot;L&quot;: [(- 300), 0], &quot;R&quot;: [300, 0]};&amp;#10;grasps = [&quot;iflex&quot;, &quot;key&quot;, &quot;tripod&quot;, &quot;wrot&quot;, &quot;rpower&quot;, &quot;wrist_flex&quot;, &quot;wrist_ext&quot;, &quot;pinch&quot;, &quot;power&quot;, &quot;point&quot;];&amp;#10;num_grasps = (2 * grasps.length);&amp;#10;stimulus_path = &quot;stimuli/{}_{}.png&quot;;&amp;#10;image_stim = {};&amp;#10;for (var grasp, _pj_c = 0, _pj_a = grasps, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    grasp = _pj_a[_pj_c];&amp;#10;    for (var side, _pj_f = 0, _pj_d = sides, _pj_e = _pj_d.length; (_pj_f &lt; _pj_e); _pj_f += 1) {&amp;#10;        side = _pj_d[_pj_f];&amp;#10;        im_path = stimulus_path.format(grasp, side);&amp;#10;        image_stim[im_path] = new visual.ImageStim({&quot;win&quot;: psychoJS.window, &quot;name&quot;: (grasp + side), &quot;units&quot;: &quot;pix&quot;, &quot;image&quot;: im_path, &quot;mask&quot;: null, &quot;anchor&quot;: &quot;center&quot;, &quot;ori&quot;: 0.0, &quot;pos&quot;: screen_position[side], &quot;draggable&quot;: false, &quot;size&quot;: [300, 300], &quot;color&quot;: [1, 1, 1], &quot;colorSpace&quot;: &quot;rgb&quot;, &quot;opacity&quot;: 1, &quot;flipHoriz&quot;: true, &quot;flipVert&quot;: false, &quot;texRes&quot;: 128.0, &quot;interpolate&quot;: true, &quot;depth&quot;: 0.0});&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="# preload images and create image_stim&amp;#10;sides = ['L', 'R']&amp;#10;screen_position = {'L': (-300, 0), 'R': (300, 0)}&amp;#10;grasps = ['iflex', 'key', 'tripod', 'wrot', 'rpower',&amp;#10;'wrist_flex', 'wrist_ext', 'pinch', 'power', 'point']&amp;#10;num_grasps = 2*len(grasps)&amp;#10;stimulus_path = 'stimuli/{}_{}.png'&amp;#10;&amp;#10;image_stim = {}&amp;#10;&amp;#10;for grasp in grasps:&amp;#10;    for side in sides:&amp;#10;        im_path = stimulus_path.format(grasp, side)&amp;#10;        image_stim[im_path] = visual.ImageStim(&amp;#10;                                    win=win,&amp;#10;                                    name=grasp+side,&amp;#10;                                    units='pix', &amp;#10;                                    image=im_path,&amp;#10;                                    mask=None,&amp;#10;                                    anchor='center',&amp;#10;                                    ori=0.0,&amp;#10;                                    pos=screen_position[side],&amp;#10;                                    draggable=False,&amp;#10;                                    size=[300, 300],&amp;#10;                                    color=[1,1,1],&amp;#10;                                    colorSpace='rgb',&amp;#10;                                    opacity=1,&amp;#10;                                    flipHoriz=True,&amp;#10;                                    flipVert=False,&amp;#10;                                    texRes=128.0,&amp;#10;                                    interpolate=True,&amp;#10;                                    depth=0.0&amp;#10;                                   )&amp;#10;                                   &amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
